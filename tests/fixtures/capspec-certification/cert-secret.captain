format = 1
name = "cert-secret"
description = "Read only a masked confirmation for one explicitly declared certification secret."
version = "1.0.0"
tags = ["certification", "security", "secret"]
output = "{{steps.read.output}}"

[permissions]
tools = ["secret_read"]
secrets = ["CAPSPEC_CERT_SECRET"]

[policy]
timeout_secs = 30

[[steps]]
id = "read"
tool = "secret_read"
with = { key = "CAPSPEC_CERT_SECRET" }
